---
import "../styles/global.css";

const {
  title = "mmadmotion — YouTube Video Editor",
  description = "YouTube video editor specializing in documentaries, explainers, talking head videos, sports, psychology, and short-form content.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <slot />
  </body>
</html>