---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const videoUrl = `https://www.youtube.com/watch?v=${project.videoId}`;
const embedUrl = `https://www.youtube.com/embed/${project.videoId}`;
---

<BaseLayout
  title={`${project.title} — MMAD Motion`}
  description={project.description}
>
  <Navbar />

  <main>
    <section class="hero project-hero">
      <p class="eyebrow">{project.category}</p>
      <h1>{project.title}</h1>
      <p class="hero-text">{project.description}</p>

      <div class="buttons">
        <a href={videoUrl} target="_blank" rel="noreferrer" class="button primary">
          Watch on YouTube
        </a>
        <a href="/work" class="button secondary">Back to Work</a>
      </div>
    </section>

    <section class="section project-detail">
      <div class="project-video">
        <iframe
          src={embedUrl}
          title={project.title}
          loading="lazy"
          allowfullscreen
        ></iframe>
      </div>

      <div class="project-info">
        <div>
          <p class="eyebrow">Role</p>
          <h3>{project.role}</h3>
        </div>

        <div>
          <p class="eyebrow">Format</p>
          <h3>{project.format}</h3>
        </div>

        <div>
          <p class="eyebrow">Editing Focus</p>
          <p>{project.focus}</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>